# SOTA Agentic OS — Environment Configuration Example
#
# Copia questo file in .env e modifica i valori secondo necessità.
# In assenza di .env, l'app gira con i default z-ai (zero config).

# === Database (WS0.2) ===
# SQLite (default dev — zero config, usa il path z-ai predefinito):
# DATABASE_URL=file:/home/z/my-project/db/custom.db
#
# SQLite con path custom:
# DATABASE_URL=file:./db/my-app.db
#
# PostgreSQL + pgvector + AGE (produzione, richiede docker-compose):
# DATABASE_URL=postgresql://sota:sota@localhost:5432/sota

# === Event Mesh (Fase 2.1) ===
# In-memory (default dev — zero config):
# (nessuna var necessaria)
#
# NATS JetStream (produzione):
# NATS_URL=nats://localhost:4222
#
# Redis Streams (alternativa):
# REDIS_URL=redis://localhost:6379

# === LLM (Fase 5.1) ===
# ZAI SDK (richiesto per LLM integration):
# ZAI_API_KEY=your-api-key-here

# === Observability (Fase 2.6) ===
# Langfuse self-host (opzionale, per trace export):
# LANGFUSE_URL=http://localhost:3001
# LANGFUSE_PUBLIC_KEY=pk-lh-...
# LANGFUSE_SECRET_KEY=sk-lh-...

# === Auth (Fase 20) ===
# Session secret (cambiare in produzione):
# SESSION_SECRET=your-session-secret
